<root>
  <BehaviorTree ID="SubTreeSceneScan">
    <Sequence name="scene_scan_fixed_viewpoints">
      <Sequence>
        <MoveToNamedConfiguration
          service_name="/concrete_block_motion_planning_node/execute_named_configuration"
          configuration_name="scan_left"
          timeout_s="20.0"
          dry_run="true"
          trajectory_id="{scan_left_traj_id}"
          move_ok="{scan_left_resolve_ok}"
          move_message="{scan_left_resolve_msg}"/>
        <ExecuteTrajectory
          service_name="/concrete_block_motion_planning_node/execute_trajectory"
          trajectory_id="{scan_left_traj_id}"
          dry_run="false"
          execution_ok="{scan_left_ok}"
          execution_message="{scan_left_msg}"/>
      </Sequence>
      <RunPoseEstimation
        service_name="/world_model_node/run_pose_estimation"
        mode="SCENE_DISCOVERY"
        target_block_id=""
        enable_debug="true"
        timeout_s="8.0"
        perception_ok="{perception_ok}"
        perception_message="{perception_message}"/>

      <Sequence>
        <MoveToNamedConfiguration
          service_name="/concrete_block_motion_planning_node/execute_named_configuration"
          configuration_name="scan_center"
          timeout_s="20.0"
          dry_run="true"
          trajectory_id="{scan_center_traj_id}"
          move_ok="{scan_center_resolve_ok}"
          move_message="{scan_center_resolve_msg}"/>
        <ExecuteTrajectory
          service_name="/concrete_block_motion_planning_node/execute_trajectory"
          trajectory_id="{scan_center_traj_id}"
          dry_run="false"
          execution_ok="{scan_center_ok}"
          execution_message="{scan_center_msg}"/>
      </Sequence>
      <RunPoseEstimation
        service_name="/world_model_node/run_pose_estimation"
        mode="SCENE_DISCOVERY"
        target_block_id=""
        enable_debug="true"
        timeout_s="8.0"
        perception_ok="{perception_ok}"
        perception_message="{perception_message}"/>

      <Sequence>
        <MoveToNamedConfiguration
          service_name="/concrete_block_motion_planning_node/execute_named_configuration"
          configuration_name="scan_right"
          timeout_s="20.0"
          dry_run="true"
          trajectory_id="{scan_right_traj_id}"
          move_ok="{scan_right_resolve_ok}"
          move_message="{scan_right_resolve_msg}"/>
        <ExecuteTrajectory
          service_name="/concrete_block_motion_planning_node/execute_trajectory"
          trajectory_id="{scan_right_traj_id}"
          dry_run="false"
          execution_ok="{scan_right_ok}"
          execution_message="{scan_right_msg}"/>
      </Sequence>
      <RunPoseEstimation
        service_name="/world_model_node/run_pose_estimation"
        mode="SCENE_DISCOVERY"
        target_block_id=""
        enable_debug="true"
        timeout_s="8.0"
        perception_ok="{perception_ok}"
        perception_message="{perception_message}"/>
    </Sequence>
  </BehaviorTree>
</root>
