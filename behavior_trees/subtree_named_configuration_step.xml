<root>
  <BehaviorTree ID="SubTreeNamedConfigurationStep">
    <Sequence>
      <MoveToNamedConfiguration
        service_name="/concrete_block_motion_planning_node/execute_named_configuration"
        configuration_name="{configuration_name}"
        timeout_s="{timeout_s}"
        dry_run="true"
        trajectory_id="{trajectory_id}"
        move_ok="{resolve_ok}"
        move_message="{resolve_message}"/>
      <ExecuteTrajectory
        service_name="/concrete_block_motion_planning_node/execute_trajectory"
        trajectory_id="{trajectory_id}"
        dry_run="{dry_run}"
        execution_ok="{move_ok}"
        execution_message="{move_message}"/>
    </Sequence>
  </BehaviorTree>
</root>
