<?xml version="1.0"?>
<root main_tree_to_execute="StackBlock1OnBlock2">
  <include path="install/concrete_block_behavior_tree/share/concrete_block_behavior_tree/behavior_trees/subtree_execute_trajectory.xml"/>
  <include path="install/concrete_block_behavior_tree/share/concrete_block_behavior_tree/behavior_trees/subtree_pick_and_place_block.xml"/>

  <BehaviorTree ID="StackBlock1OnBlock2">
    <Sequence name="stack_block_1_on_block_2">

      <SyncGazeboBlocksToWorldModel name="Discover blocks from Gazebo"
        block_ids="block_1,block_2"
        gazebo_state_service="/gazebo/get_entity_state"
        upsert_service="/world_model_node/upsert_block"
        gazebo_reference_frame="world"
        world_frame_id="K0_mounting_base"
        gazebo_seed_frame_xyz="6.93852,-6.35,1.1407"
        gazebo_seed_frame_rpy_deg="0.0,0.0,0.0"
        service_timeout_ms="5000"/>

      <!-- Shared skill parameters -->
      <SetBlackboard output_key="slow_down" value="1.0"/>
      <SetBlackboard output_key="s_log_8_x" value="0.0"/>
      <SetBlackboard output_key="approach_z" value="2.0"/>
      <SetBlackboard output_key="carry_approach_z" value="2.6"/>
      <SetBlackboard output_key="grasp_object_contains" value="block_1"/>
      <!-- Block approximated as cylinder for timber planner compatibility -->
      <SetBlackboard output_key="logShape"
        value="{radius_top: 0.30, radius_bottom: 0.30, length: 0.90}"/>
      <!-- CBS has no log-scene perception; CalcA2BMovement requires the
           port to be connected so we seed it with an empty value. -->
      <SetBlackboard output_key="logsScene" value=""/>

      <GetNextAssemblyTask
        service_name="/concrete_block_wall_plan_server/get_next_assembly_task"
        server_timeout="10000"
        wall_plan_name="stack_block_1_on_block_2"
        reset_plan="true"
        task_id="{task_id}"
        target_block_id="{target_block_id}"
        reference_block_id="{reference_block_id}"
        target_block_pose_coarse="{target_block_pose_coarse}"
        target_block_pose_precise="{target_block_pose_precise}"
        reference_block_pose_precise="{reference_block_pose_precise}"
        plan_has_task="{plan_has_task}"
        plan_message="{plan_message}"
        pickup_x="{pickup_x}"
        pickup_y="{pickup_y}"
        pickup_z="{pickup_z}"
        pickup_yaw="{pickup_yaw}"
        place_x="{place_x}"
        place_y="{place_y}"
        place_z="{place_z}"
        place_yaw="{place_yaw}"/>

      <SetBlackboard output_key="place_approach_x" value="{place_x}"/>
      <SetBlackboard output_key="place_approach_y" value="{place_y}"/>
      <SetBlackboard output_key="grasp_object_contains" value="{target_block_id}"/>

      <SubTree ID="SubTreePickAndPlaceBlock" __shared_blackboard="true"/>

    </Sequence>
  </BehaviorTree>
</root>
