<root main_tree_to_execute="ScanSequenceSmoke">
  <BehaviorTree ID="ScanSequenceSmoke">
    <Sequence>
      <Sequence>
        <MoveToNamedConfiguration
          service_name="/concrete_block_motion_planning_node/execute_named_configuration"
          configuration_name="scan_left"
          timeout_s="20.0"
          dry_run="true"
          trajectory_id="{scan_left_traj_id}"
          move_ok="{scan_left_resolve_ok}"
          move_message="{scan_left_resolve_msg}"/>
        <ExecuteTrajectory
          service_name="/concrete_block_motion_planning_node/execute_trajectory"
          trajectory_id="{scan_left_traj_id}"
          dry_run="false"
          execution_ok="{scan_left_ok}"
          execution_message="{scan_left_msg}"/>
      </Sequence>
      <RunPoseEstimation
        service_name="/world_model_node/run_pose_estimation"
        mode="SCENE_DISCOVERY"
        target_block_id=""
        enable_debug="true"
        timeout_s="8.0"
        perception_ok="{perception_ok}"
        perception_message="{perception_message}"/>

      <Sequence>
        <MoveToNamedConfiguration
          service_name="/concrete_block_motion_planning_node/execute_named_configuration"
          configuration_name="scan_center"
          timeout_s="20.0"
          dry_run="true"
          trajectory_id="{scan_center_traj_id}"
          move_ok="{scan_center_resolve_ok}"
          move_message="{scan_center_resolve_msg}"/>
        <ExecuteTrajectory
          service_name="/concrete_block_motion_planning_node/execute_trajectory"
          trajectory_id="{scan_center_traj_id}"
          dry_run="false"
          execution_ok="{scan_center_ok}"
          execution_message="{scan_center_msg}"/>
      </Sequence>
      <RunPoseEstimation
        service_name="/world_model_node/run_pose_estimation"
        mode="SCENE_DISCOVERY"
        target_block_id=""
        enable_debug="true"
        timeout_s="8.0"
        perception_ok="{perception_ok}"
        perception_message="{perception_message}"/>

      <Sequence>
        <MoveToNamedConfiguration
          service_name="/concrete_block_motion_planning_node/execute_named_configuration"
          configuration_name="scan_right"
          timeout_s="20.0"
          dry_run="true"
          trajectory_id="{scan_right_traj_id}"
          move_ok="{scan_right_resolve_ok}"
          move_message="{scan_right_resolve_msg}"/>
        <ExecuteTrajectory
          service_name="/concrete_block_motion_planning_node/execute_trajectory"
          trajectory_id="{scan_right_traj_id}"
          dry_run="false"
          execution_ok="{scan_right_ok}"
          execution_message="{scan_right_msg}"/>
      </Sequence>
      <RunPoseEstimation
        service_name="/world_model_node/run_pose_estimation"
        mode="SCENE_DISCOVERY"
        target_block_id=""
        enable_debug="true"
        timeout_s="8.0"
        perception_ok="{perception_ok}"
        perception_message="{perception_message}"/>

      <GetNextAssemblyTask
        service_name="/concrete_block_motion_planning_node/get_next_assembly_task"
        wall_plan_name="basic_interlocking_3_2"
        reset_plan="true"
        task_id="{task_id}"
        target_block_id="{target_block_id}"
        reference_block_id="{reference_block_id}"
        target_block_pose_coarse="{target_block_pose_coarse}"
        target_block_pose_precise="{target_block_pose_precise}"
        reference_block_pose_precise="{reference_block_pose_precise}"
        plan_has_task="{plan_has_task}"
        plan_message="{plan_message}"/>

      <PlanGeometricPath
        service_name="/concrete_block_motion_planning_node/plan_geometric_path"
        start_pose="{target_block_pose_coarse}"
        goal_pose="{target_block_pose_precise}"
        target_block_id="{target_block_id}"
        reference_block_id="{reference_block_id}"
        method="POWELL"
        timeout_s="5.0"
        use_world_model="true"
        geometric_plan_id="{geometric_plan_id}"
        cartesian_path="{cartesian_path}"
        geometric_ok="{geometric_ok}"
        geometric_message="{geometric_message}"/>
    </Sequence>
  </BehaviorTree>
</root>
