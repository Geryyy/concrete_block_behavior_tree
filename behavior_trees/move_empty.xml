<?xml version="1.0"?>
<root main_tree_to_execute="MoveEmpty">
  <BehaviorTree ID="MoveEmpty">
    <Sequence>
      <SetBlackboard output_key="slow_down" value="1.0"/>
      <Decorator ID="RetryUntilSuccessful" num_attempts="-1">
        <Decorator ID="WaitGoalPose" goal="{yN}" phi="{phi}" topic="goal_pose" z_offset="3.5">
          <Sequence>
            <Action ID="OptimizeTargetAngle" phi="{phi}"/>
            <Action ID="PrepareMoveEmptyRequest"
              name="Prepare move request"
              goal="{yN}"
              phi="{phi}"
              source_frame="K8_tool_center_point"
              target_frame="K0_mounting_base"
              start_pose="{start_pose}"
              goal_pose="{goal_pose}"/>
            <PlanAndComputeTrajectory
              name="Calc approach target"
              service_name="/concrete_block_motion_planning_node/plan_and_compute_trajectory"
              start_pose="{start_pose}"
              goal_pose="{goal_pose}"
              use_world_model="false"
              validate_dynamics="false"
              geometric_timeout_s="5.0"
              trajectory_timeout_s="10.0"
              trajectory_id="{trajectory_id}"
              joint_trajectory="{joint_trajectory}"
              trajectory_ok="{trajectory_ok}"
              trajectory_message="{trajectory_message}"/>
            <Condition ID="CheckUserApproval" topic="/gpio_controller/remote_ctrl_states"/>
          </Sequence>
        </Decorator>
      </Decorator>
      <Decorator ID="GetUserApproval" topic="/gpio_controller/remote_ctrl_states"
        wait_rising_edge="False">
        <Sequence>
          <ExecuteTrajectory
            name="Execute planned trajectory"
            service_name="/concrete_block_motion_planning_node/execute_trajectory"
            trajectory_id="{trajectory_id}"
            dry_run="false"
            execution_ok="{execution_ok}"
            execution_message="{execution_message}"/>
        </Sequence>
      </Decorator>
    </Sequence>
  </BehaviorTree>
  <TreeNodesModel>
    <Action ID="PrepareMoveEmptyRequest">
      <input_port name="goal">Target point in target_frame</input_port>
      <input_port name="phi">Target yaw in target_frame</input_port>
      <input_port name="source_frame">Tool frame to sample current pose from</input_port>
      <input_port name="target_frame">Frame for planner request poses</input_port>
      <output_port name="start_pose">Current tool pose as PoseStamped</output_port>
      <output_port name="goal_pose">Planner goal pose as PoseStamped</output_port>
    </Action>
    <Action ID="PlanAndComputeTrajectory">
      <input_port name="service_name">Name of the service</input_port>
      <input_port name="start_pose">Start pose</input_port>
      <input_port name="goal_pose">Goal pose</input_port>
      <input_port name="target_block_id">Target block id</input_port>
      <input_port name="reference_block_id">Reference block id</input_port>
      <input_port name="use_world_model">Use current world model</input_port>
      <input_port name="geometric_method">Geometric planning method</input_port>
      <input_port name="geometric_timeout_s">Geometric planning timeout</input_port>
      <input_port name="trajectory_method">Trajectory method</input_port>
      <input_port name="trajectory_timeout_s">Trajectory timeout</input_port>
      <input_port name="validate_dynamics">Require dynamics validation</input_port>
      <output_port name="geometric_plan_id">Geometric plan id</output_port>
      <output_port name="cartesian_path">Cartesian path</output_port>
      <output_port name="trajectory_id">Stored trajectory id</output_port>
      <output_port name="joint_trajectory">Computed trajectory</output_port>
      <output_port name="trajectory_ok">Planning success flag</output_port>
      <output_port name="trajectory_message">Planning message</output_port>
    </Action>
    <Action ID="ExecuteTrajectory">
      <input_port name="service_name">Name of the service</input_port>
      <input_port name="trajectory_id">Stored trajectory id</input_port>
      <input_port name="dry_run">Execute as dry run</input_port>
      <output_port name="execution_ok">Execution success flag</output_port>
      <output_port name="execution_message">Execution message</output_port>
    </Action>
    <Decorator ID="GetUserApproval">
      <input_port name="topic">Topic to listen on</input_port>
    </Decorator>
    <Decorator ID="WaitGoalPose">
      <output_port name="goal">Pose of goal</output_port>
      <output_port name="phi">Desired log phi</output_port>
      <input_port name="topic">Topic to listen on</input_port>
      <input_port name="z_offset">Offset to add to z_0 direction</input_port>
    </Decorator>
  </TreeNodesModel>
</root>
