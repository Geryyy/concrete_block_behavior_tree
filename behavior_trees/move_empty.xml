<?xml version="1.0"?>
<root main_tree_to_execute="MoveEmpty">
  <include path="install/concrete_block_behavior_tree/share/concrete_block_behavior_tree/behavior_trees/subtree_execute_trajectory.xml"/>
  <!-- ////////// -->
  <BehaviorTree ID="MoveEmpty">
    <Sequence>
      <SetBlackboard output_key="slow_down" value="1.0"/>
      <Decorator ID="RetryUntilSuccessful" num_attempts="-1">
        <Decorator ID="WaitGoalPose" goal="{yN}" phi="{phi}" topic="goal_pose" z_offset="3.5">
          <Sequence>
            <Action ID="OptimizeTargetAngle" phi="{phi}"/>
            <Action ID="CalcA2BMovement" carriesLog="false"
              name="Calc approach target" phiToolN="{phi}"
              server_timeout="10000" service_name="a2b_movement"
              slowDown="{slow_down}" tEnd="0.0"
              trajectory="{trajectory}" yN="{yN}"/>
            <Condition ID="CheckUserApproval" topic="/gpio_controller/remote_ctrl_states"/>
          </Sequence>
        </Decorator>
      </Decorator>
      <SubTree ID="SubTreeExecuteTrajectory" __shared_blackboard="true"/>
    </Sequence>
  </BehaviorTree>
  <!-- ////////// -->
  <TreeNodesModel>
    <Action ID="CalcA2BMovement">
      <input_port name="carriesLog">Carrying payload?</input_port>
      <input_port name="phiToolN">Gripper yaw</input_port>
      <input_port name="server_timeout">Timeout (ms)</input_port>
      <input_port name="service_name">Service name</input_port>
      <input_port name="slowDown">Speed factor</input_port>
      <input_port name="tEnd">Fixed end time (0=auto)</input_port>
      <output_port name="trajectory">Computed trajectory</output_port>
      <input_port name="yN">Target position</input_port>
    </Action>
    <Action ID="FollowJointTrajectory">
      <input_port name="server_name">Action server</input_port>
      <input_port name="server_timeout">Timeout (ms)</input_port>
      <input_port name="trajectory">Trajectory to follow</input_port>
    </Action>
    <Decorator ID="GetUserApproval">
      <input_port name="topic">Topic</input_port>
    </Decorator>
    <Decorator ID="WaitGoalPose">
      <output_port name="goal">Pose of goal</output_port>
      <output_port name="phi">Desired yaw</output_port>
      <input_port name="topic">Topic to listen on</input_port>
      <input_port name="z_offset">Offset to add to z direction</input_port>
    </Decorator>
  </TreeNodesModel>
  <!-- ////////// -->
</root>
