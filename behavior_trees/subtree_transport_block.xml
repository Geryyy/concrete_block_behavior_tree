<root>
  <BehaviorTree ID="SubTreeTransportBlock">
    <Sequence name="transport_block_sequence">
      <!-- Close gripper to grasp block at pickup pose (stub for simulation) -->
      <GripperAction command="CLOSE"/>

      <Fallback name="geometric_stage_with_retry">
        <PlanGeometricPath
          service_name="/concrete_block_motion_planning_node/plan_geometric_path"
          start_pose="{target_block_pose_coarse}"
          goal_pose="{target_block_pose_precise}"
          target_block_id="{target_block_id}"
          reference_block_id="{reference_block_id}"
          method="POWELL"
          timeout_s="5.0"
          use_world_model="true"
          geometric_plan_id="{geometric_plan_id}"
          cartesian_path="{cartesian_path}"
          geometric_ok="{geometric_ok}"
          geometric_message="{geometric_message}"/>

        <Sequence name="geometric_retry_alt_method">
          <RunPoseEstimation
            service_name="/world_model_node/run_pose_estimation"
            mode="SCENE_DISCOVERY"
            target_block_id=""
            enable_debug="false"
            timeout_s="8.0"
            perception_ok="{perception_ok}"
            perception_message="{perception_message}"/>
          <PlanGeometricPath
            service_name="/concrete_block_motion_planning_node/plan_geometric_path"
            start_pose="{target_block_pose_coarse}"
            goal_pose="{target_block_pose_precise}"
            target_block_id="{target_block_id}"
            reference_block_id="{reference_block_id}"
            method="CEM"
            timeout_s="5.0"
            use_world_model="true"
            geometric_plan_id="{geometric_plan_id}"
            cartesian_path="{cartesian_path}"
            geometric_ok="{geometric_ok}"
            geometric_message="{geometric_message}"/>
        </Sequence>
      </Fallback>

      <Fallback name="trajectory_stage_with_retry">
        <ComputeTrajectory
          service_name="/concrete_block_motion_planning_node/compute_trajectory"
          geometric_plan_id="{geometric_plan_id}"
          cartesian_path="{cartesian_path}"
          use_direct_path="false"
          method="ACADOS_PATH_FOLLOWING_STABLE"
          timeout_s="10.0"
          validate_dynamics="true"
          trajectory_id="{trajectory_id}"
          joint_trajectory="{joint_trajectory}"
          trajectory_ok="{trajectory_ok}"
          trajectory_message="{trajectory_message}"/>

        <ComputeTrajectory
          service_name="/concrete_block_motion_planning_node/compute_trajectory"
          geometric_plan_id="{geometric_plan_id}"
          cartesian_path="{cartesian_path}"
          use_direct_path="false"
          method="ACADOS_PATH_FOLLOWING_FAST"
          timeout_s="10.0"
          validate_dynamics="false"
          trajectory_id="{trajectory_id}"
          joint_trajectory="{joint_trajectory}"
          trajectory_ok="{trajectory_ok}"
          trajectory_message="{trajectory_message}"/>
      </Fallback>

      <ExecuteTrajectory
        service_name="/concrete_block_motion_planning_node/execute_trajectory"
        trajectory_id="{trajectory_id}"
        dry_run="false"
        execution_ok="{execution_ok}"
        execution_message="{execution_message}"/>

      <!-- Open gripper to release block at placement pose (stub for simulation) -->
      <GripperAction command="OPEN"/>
    </Sequence>
  </BehaviorTree>
</root>
