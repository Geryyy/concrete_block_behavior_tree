<root>
  <BehaviorTree ID="SubTreeTransportBlock">
    <Sequence name="transport_block_sequence">
      <PrepareSingleBlockRequest
        target_pose="{target_block_pose_coarse}"
        source_frame="K8_tool_center_point"
        target_frame="world"
        approach_offset_m="2.0"
        start_pose="{pickup_approach_start_pose}"
        goal_pose="{pickup_approach_goal_pose}"/>

      <PlanAndComputeTrajectory
        service_name="/concrete_block_motion_planning_node/plan_and_compute_trajectory"
        start_pose="{pickup_approach_start_pose}"
        goal_pose="{pickup_approach_goal_pose}"
        target_block_id="{target_block_id}"
        reference_block_id="{reference_block_id}"
        use_world_model="true"
        geometric_method="POWELL"
        geometric_timeout_s="5.0"
        trajectory_method="TIMBER_MOVE_EMPTY"
        trajectory_timeout_s="20.0"
        validate_dynamics="false"
        geometric_plan_id="{pickup_approach_plan_id}"
        cartesian_path="{pickup_approach_path}"
        trajectory_id="{pickup_approach_trajectory_id}"
        joint_trajectory="{pickup_approach_joint_trajectory}"
        trajectory_ok="{pickup_approach_ok}"
        trajectory_message="{pickup_approach_message}"/>

      <ExecuteTrajectory
        service_name="/concrete_block_motion_planning_node/execute_trajectory"
        trajectory_id="{pickup_approach_trajectory_id}"
        dry_run="false"
        execution_ok="{pickup_approach_execution_ok}"
        execution_message="{pickup_approach_execution_message}"/>

      <PlanAndComputeTrajectory
        service_name="/concrete_block_motion_planning_node/plan_and_compute_trajectory"
        start_pose="{pickup_approach_goal_pose}"
        goal_pose="{pickup_goal_pose}"
        target_block_id="{target_block_id}"
        reference_block_id="{reference_block_id}"
        use_world_model="true"
        geometric_method="POWELL"
        geometric_timeout_s="5.0"
        trajectory_method="TIMBER_GRIP"
        trajectory_timeout_s="40.0"
        validate_dynamics="false"
        geometric_plan_id="{grip_plan_id}"
        cartesian_path="{grip_path}"
        trajectory_id="{grip_trajectory_id}"
        joint_trajectory="{grip_joint_trajectory}"
        trajectory_ok="{grip_ok}"
        trajectory_message="{grip_message}"/>

      <ExecuteTrajectory
        service_name="/concrete_block_motion_planning_node/execute_trajectory"
        trajectory_id="{grip_trajectory_id}"
        dry_run="false"
        execution_ok="{grip_execution_ok}"
        execution_message="{grip_execution_message}"/>

      <GripperAction
        command="CLOSE"
        block_id="{target_block_id}"
        payload_mass_kg="800.0"
        payload_length_m="0.9"
        payload_radius_m="0.3"
        grip_point_x="0.0"
        grip_point_y="0.0"
        grip_point_z="0.0"/>

      <PlanAndComputeTrajectory
        service_name="/concrete_block_motion_planning_node/plan_and_compute_trajectory"
        start_pose="{pickup_goal_pose}"
        goal_pose="{pickup_goal_pose}"
        target_block_id="{target_block_id}"
        reference_block_id="{reference_block_id}"
        use_world_model="true"
        geometric_method="POWELL"
        geometric_timeout_s="5.0"
        trajectory_method="TIMBER_LIFT"
        trajectory_timeout_s="40.0"
        validate_dynamics="false"
        geometric_plan_id="{lift_plan_id}"
        cartesian_path="{lift_path}"
        trajectory_id="{lift_trajectory_id}"
        joint_trajectory="{lift_joint_trajectory}"
        trajectory_ok="{lift_ok}"
        trajectory_message="{lift_message}"/>

      <ExecuteTrajectory
        service_name="/concrete_block_motion_planning_node/execute_trajectory"
        trajectory_id="{lift_trajectory_id}"
        dry_run="false"
        execution_ok="{lift_execution_ok}"
        execution_message="{lift_execution_message}"/>

      <PrepareSingleBlockRequest
        target_pose="{target_block_pose_precise}"
        source_frame="K8_tool_center_point"
        target_frame="world"
        approach_offset_m="2.0"
        start_pose="{place_approach_start_pose}"
        goal_pose="{place_approach_goal_pose}"/>

      <PlanAndComputeTrajectory
        service_name="/concrete_block_motion_planning_node/plan_and_compute_trajectory"
        start_pose="{place_approach_start_pose}"
        goal_pose="{place_approach_goal_pose}"
        target_block_id="{target_block_id}"
        reference_block_id="{reference_block_id}"
        use_world_model="true"
        geometric_method="POWELL"
        geometric_timeout_s="5.0"
        trajectory_method="TIMBER_MOVE_LOADED"
        trajectory_timeout_s="20.0"
        validate_dynamics="false"
        geometric_plan_id="{place_approach_plan_id}"
        cartesian_path="{place_approach_path}"
        trajectory_id="{place_approach_trajectory_id}"
        joint_trajectory="{place_approach_joint_trajectory}"
        trajectory_ok="{place_approach_ok}"
        trajectory_message="{place_approach_message}"/>

      <ExecuteTrajectory
        service_name="/concrete_block_motion_planning_node/execute_trajectory"
        trajectory_id="{place_approach_trajectory_id}"
        dry_run="false"
        execution_ok="{place_approach_execution_ok}"
        execution_message="{place_approach_execution_message}"/>

      <PrepareSingleBlockRequest
        target_pose="{target_block_pose_precise}"
        source_frame="K8_tool_center_point"
        target_frame="world"
        approach_offset_m="0.0"
        start_pose="{place_start_pose}"
        goal_pose="{place_goal_pose}"/>

      <PlanAndComputeTrajectory
        service_name="/concrete_block_motion_planning_node/plan_and_compute_trajectory"
        start_pose="{place_start_pose}"
        goal_pose="{place_goal_pose}"
        target_block_id="{target_block_id}"
        reference_block_id="{reference_block_id}"
        use_world_model="true"
        geometric_method="POWELL"
        geometric_timeout_s="5.0"
        trajectory_method="TIMBER_MOVE_LOADED"
        trajectory_timeout_s="20.0"
        validate_dynamics="false"
        geometric_plan_id="{place_plan_id}"
        cartesian_path="{place_path}"
        trajectory_id="{place_trajectory_id}"
        joint_trajectory="{place_joint_trajectory}"
        trajectory_ok="{place_ok}"
        trajectory_message="{place_message}"/>

      <ExecuteTrajectory
        service_name="/concrete_block_motion_planning_node/execute_trajectory"
        trajectory_id="{place_trajectory_id}"
        dry_run="false"
        execution_ok="{place_execution_ok}"
        execution_message="{place_execution_message}"/>

      <PlanAndComputeTrajectory
        service_name="/concrete_block_motion_planning_node/plan_and_compute_trajectory"
        start_pose="{place_goal_pose}"
        goal_pose="{place_goal_pose}"
        target_block_id="{target_block_id}"
        reference_block_id="{reference_block_id}"
        use_world_model="true"
        geometric_method="POWELL"
        geometric_timeout_s="5.0"
        trajectory_method="TIMBER_LAYDOWN"
        trajectory_timeout_s="40.0"
        validate_dynamics="false"
        geometric_plan_id="{laydown_plan_id}"
        cartesian_path="{laydown_path}"
        trajectory_id="{laydown_trajectory_id}"
        joint_trajectory="{laydown_joint_trajectory}"
        trajectory_ok="{laydown_ok}"
        trajectory_message="{laydown_message}"/>

      <ExecuteTrajectory
        service_name="/concrete_block_motion_planning_node/execute_trajectory"
        trajectory_id="{laydown_trajectory_id}"
        dry_run="false"
        execution_ok="{laydown_execution_ok}"
        execution_message="{laydown_execution_message}"/>

      <GripperAction command="OPEN"/>
    </Sequence>
  </BehaviorTree>
</root>
