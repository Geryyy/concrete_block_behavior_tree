<root main_tree_to_execute="ConcreteBlockAssembly">
  <include
    path="install/concrete_block_behavior_tree/share/concrete_block_behavior_tree/behavior_trees/subtree_scene_scan.xml"/>
  <include
    path="install/concrete_block_behavior_tree/share/concrete_block_behavior_tree/behavior_trees/subtree_transport_block.xml"/>
  <include
    path="install/concrete_block_behavior_tree/share/concrete_block_behavior_tree/behavior_trees/subtree_recovery_scan.xml"/>
  <BehaviorTree ID="ConcreteBlockAssembly">
    <!--
      KeepRunningUntilFailure loops the inner sequence until it returns FAILURE.
      GetNextAssemblyTask returns FAILURE when the wall plan is complete,
      which propagates through the sequence and terminates the loop with SUCCESS.
    -->
    <KeepRunningUntilFailure name="assembly_loop">
      <Sequence name="scan_and_execute">
        <SubTree ID="SubTreeSceneScan" __shared_blackboard="true"/>

        <GetNextAssemblyTask
          service_name="/concrete_block_motion_planning_node/get_next_assembly_task"
          wall_plan_name="basic_interlocking_3_2"
          reset_plan="false"
          task_id="{task_id}"
          target_block_id="{target_block_id}"
          reference_block_id="{reference_block_id}"
          target_block_pose_coarse="{target_block_pose_coarse}"
          target_block_pose_precise="{target_block_pose_precise}"
          reference_block_pose_precise="{reference_block_pose_precise}"
          plan_has_task="{plan_has_task}"
          plan_message="{plan_message}"/>

        <!--
          Execution with recovery: perception/planning failures trigger a recovery
          scan and retry from the current block. GetNextAssemblyTask failures (no
          tasks left) are NOT caught here — they propagate up to terminate the loop.
        -->
        <Fallback name="execute_with_recovery">
          <Sequence name="execute_sequence">
            <RunPoseEstimation
              service_name="/world_model_node/run_pose_estimation"
              mode="REFINE_BLOCK"
              target_block_id="{target_block_id}"
              enable_debug="true"
              timeout_s="8.0"
              perception_ok="{perception_ok}"
              perception_message="{perception_message}"/>

            <SubTree ID="SubTreeTransportBlock" __shared_blackboard="true"/>

            <RunPoseEstimation
              service_name="/world_model_node/run_pose_estimation"
              mode="REFINE_GRASPED"
              target_block_id="{target_block_id}"
              enable_debug="true"
              timeout_s="8.0"
              perception_ok="{perception_ok}"
              perception_message="{perception_message}"/>

            <SetBlockTaskStatus
              service_name="/world_model_node/set_block_task_status"
              block_id="{target_block_id}"
              task_status="3"
              status_ok="{status_ok}"
              status_message="{status_message}"/>
          </Sequence>

          <SubTree ID="SubTreeRecoveryScan" __shared_blackboard="true"/>
        </Fallback>
      </Sequence>
    </KeepRunningUntilFailure>
  </BehaviorTree>
</root>
